<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Line?>
<?import javafx.scene.shape.Rectangle?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.markbaengine.controller.DatabaseSetupController"
           styleClass="setup-root">

    <children>
        <!-- Background scene. These fx:id values are required by DatabaseSetupController. -->
        <Pane fx:id="bgScene" styleClass="bg-scene">
            <children>
                <Rectangle fx:id="skyRect" styleClass="scene-sky-bg" />
                <Pane fx:id="windLinesPane" mouseTransparent="true" pickOnBounds="false" />

                <Rectangle fx:id="greenBand" styleClass="landscape-band" />
                <Rectangle fx:id="roadBand" styleClass="road-band" />
                <Line fx:id="roadTop" styleClass="road-edge" />
                <Line fx:id="roadBottom" styleClass="road-edge-soft" />
                <Pane fx:id="laneLinesPane" mouseTransparent="true" pickOnBounds="false" />

                <Circle fx:id="treeL1" radius="20" styleClass="tree-crown" />
                <Rectangle fx:id="trunkL1" width="7" height="28" arcWidth="4" arcHeight="4" styleClass="tree-trunk" />
                <Rectangle fx:id="houseL" width="64" height="46" arcWidth="8" arcHeight="8" styleClass="simple-house" />
                <Line fx:id="roofL1" styleClass="house-roof" />
                <Line fx:id="roofL2" styleClass="house-roof" />
                <Rectangle fx:id="winL" width="13" height="13" arcWidth="3" arcHeight="3" styleClass="house-window" />
                <Circle fx:id="treeL2" radius="16" styleClass="tree-crown-soft" />
                <Rectangle fx:id="trunkL2" width="6" height="24" arcWidth="4" arcHeight="4" styleClass="tree-trunk" />

                <Circle fx:id="treeR1" radius="17" styleClass="tree-crown-soft" />
                <Rectangle fx:id="trunkR1" width="6" height="25" arcWidth="4" arcHeight="4" styleClass="tree-trunk" />
                <Circle fx:id="treeR2" radius="21" styleClass="tree-crown" />
                <Rectangle fx:id="trunkR2" width="7" height="30" arcWidth="4" arcHeight="4" styleClass="tree-trunk" />
                <Rectangle fx:id="houseR" width="74" height="40" arcWidth="8" arcHeight="8" styleClass="simple-house-soft" />
                <Line fx:id="roofR1" styleClass="house-roof-soft" />
                <Line fx:id="roofR2" styleClass="house-roof-soft" />
            </children>
        </Pane>

        <VBox alignment="CENTER" maxWidth="930" maxHeight="680" spacing="15" styleClass="setup-panel">
            <padding>
                <Insets top="24" right="30" bottom="24" left="30" />
            </padding>
            <children>
                <!--
                    DatabaseSetupController injects the old stylized Markba logo into this node.
                    It is intentionally kept hidden because that injected logo is decorative and can overflow.
                    The visible brand below is a compact, stable MarkbaEngine label.
                -->
                <StackPane fx:id="logoContainer" managed="false" visible="false" minWidth="0" minHeight="0" prefWidth="0" prefHeight="0" maxWidth="0" maxHeight="0" />

                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="setup-brand-row">
                    <children>
                        <StackPane minWidth="34" prefWidth="34" maxWidth="34" minHeight="34" prefHeight="34" maxHeight="34" styleClass="setup-brand-mark">
                            <children>
                                <Label text="M" styleClass="setup-brand-mark-text" />
                            </children>
                        </StackPane>
                        <Label text="MarkbaEngine" styleClass="setup-brand-name" />
                    </children>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="16" styleClass="setup-hero">
                    <children>
                        <StackPane minWidth="62" prefWidth="62" maxWidth="62" minHeight="62" prefHeight="62" maxHeight="62" styleClass="setup-db-icon">
                            <children>
                                <Label text="DB" styleClass="setup-db-icon-text" />
                            </children>
                        </StackPane>
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="Urban Fleet Database Workspace" styleClass="setup-title" />
                                <Label text="Load an existing workspace or create a new empty database to get started."
                                       wrapText="true" styleClass="setup-subtitle" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <HBox spacing="18" styleClass="setup-choice-row">
                    <children>
                        <VBox spacing="10" maxWidth="Infinity" HBox.hgrow="ALWAYS" styleClass="setup-choice-card setup-choice-card-primary">
                            <padding>
                                <Insets top="18" right="20" bottom="18" left="20" />
                            </padding>
                            <children>
                                <Label text="Load Existing Workspace" styleClass="setup-choice-title" />
                                <Label text="Choose a schema-specific .sql file and convert it into a local workspace database."
                                       wrapText="true" styleClass="setup-choice-copy" />
                                <Region VBox.vgrow="ALWAYS" />
                                <Button text="Choose SQL File" onAction="#chooseSqlFile" maxWidth="Infinity" styleClass="setup-action-primary" />
                            </children>
                        </VBox>

                        <VBox spacing="10" maxWidth="Infinity" HBox.hgrow="ALWAYS" styleClass="setup-choice-card">
                            <padding>
                                <Insets top="18" right="20" bottom="18" left="20" />
                            </padding>
                            <children>
                                <Label text="Create New Workspace" styleClass="setup-choice-title" />
                                <Label text="Generate an empty database with all required tables, then start adding records."
                                       wrapText="true" styleClass="setup-choice-copy" />
                                <Region VBox.vgrow="ALWAYS" />
                                <Button text="Create Empty Database" onAction="#createEmptyDatabase" maxWidth="Infinity" styleClass="setup-action-secondary" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <VBox spacing="12" styleClass="setup-section-card">
                    <padding>
                        <Insets top="16" right="18" bottom="16" left="18" />
                    </padding>
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <children>
                                <Label text="SQL File" styleClass="setup-section-title" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Button text="Browse" onAction="#chooseSqlFile" styleClass="setup-browse-button" />
                            </children>
                        </HBox>

                        <Label fx:id="selectedFileLabel" text="No SQL file selected yet."
                               maxWidth="Infinity" styleClass="setup-file-field" />

                        <VBox spacing="7" styleClass="setup-status-panel">
                            <padding>
                                <Insets top="12" right="14" bottom="12" left="14" />
                            </padding>
                            <children>
                                <Label text="Workspace status" styleClass="setup-status-title" />
                                <Label fx:id="workspacePathLabel" text="Workspace database: not created yet."
                                       wrapText="true" styleClass="workspace-path-label" />
                                <TextArea fx:id="validationTextArea" editable="false" focusTraversable="false"
                                          wrapText="true" prefRowCount="2" prefHeight="58" minHeight="58"
                                          styleClass="setup-validation-box" />
                            </children>
                        </VBox>
                    </children>
                </VBox>

                <VBox spacing="10" styleClass="setup-section-card setup-required-card">
                    <padding>
                        <Insets top="14" right="18" bottom="14" left="18" />
                    </padding>
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <children>
                                <Label text="Required Tables" styleClass="setup-section-title" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Label text="8 tables" styleClass="setup-count-badge" />
                            </children>
                        </HBox>
                        <Label fx:id="requiredTablesLabel" wrapText="true" styleClass="required-tables-summary" />
                        <FlowPane hgap="8" vgap="8" styleClass="required-chip-row">
                            <children>
                                <Label text="depot" styleClass="required-chip" />
                                <Label text="vehicle_model" styleClass="required-chip" />
                                <Label text="vehicle" styleClass="required-chip" />
                                <Label text="mechanic" styleClass="required-chip" />
                                <Label text="Fuel Types" styleClass="required-chip" />
                                <Label text="spare_part" styleClass="required-chip" />
                                <Label text="maintenance_log" styleClass="required-chip" />
                                <Label text="part_usage" styleClass="required-chip" />
                            </children>
                        </FlowPane>
                    </children>
                </VBox>

                <Button fx:id="continueButton" text="Continue to Dashboard" onAction="#continueToDashboard"
                        maxWidth="Infinity" styleClass="setup-continue-btn" />

                <HBox alignment="CENTER" spacing="12" styleClass="setup-footer-row">
                    <children>
                        <Label text="All data is stored locally on this device." styleClass="setup-footer-text" />
                        <Button text="Use Demo Workspace" onAction="#useDemoWorkspace" styleClass="setup-demo-link" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</StackPane>
